# Solana RPC — devnet is fine for the tutorial
VITE_RPC_URL=https://api.devnet.solana.com

# Veilo relayer (default points at the hosted devnet relayer)
VITE_VEILO_RELAYER_URL=https://relayer-server.onrender.com
VITE_VEILO_API_KEY=replace-me
# Base64-encoded NaCl public key of the relayer (used to encrypt withdraw payloads).
# Ask whoever runs the relayer for this value.
VITE_VEILO_RELAYER_PUBKEY=replace-me

# Devnet USDC mint (official Circle devnet USDC)
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
